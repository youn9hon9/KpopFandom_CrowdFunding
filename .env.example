# Duckrowd Environment Variables

# Server Port
PORT=3000

# Base URL for Redirect URIs (e.g. http://localhost:3000 or http://127.0.0.1:3000)
REDIRECT_URI_BASE=http://localhost:3000

# Google OAuth 2.0 Credentials
# Get these from Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Kakao OAuth 2.0 Credentials
# Get REST API key from Kakao Developers Console (https://developers.kakao.com/)
KAKAO_CLIENT_ID=your_kakao_client_id_here
# Optional: Client Secret (if enabled in Kakao login security settings)
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here
