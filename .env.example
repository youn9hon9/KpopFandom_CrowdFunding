# Duckrowd Environment Variables
# Copy this file to .env and fill in your OAuth credentials.

# Server Port
PORT=3000

# SQLite database file (created automatically on first start)
# DATABASE_PATH=./data/duckrowd.db

# Base URL for Redirect URIs — MUST match the URL you open in the browser exactly.
# Common pitfall: http://localhost:3000 vs http://127.0.0.1:3000 are treated as different origins.
REDIRECT_URI_BASE=http://localhost:3000

# Google OAuth 2.0 (OpenID Connect)
# Console: https://console.cloud.google.com/
# APIs & Services > Credentials > OAuth 2.0 Client IDs > Web application
# Authorized redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Kakao OAuth 2.0
# Console: https://developers.kakao.com/
# Use the REST API key (not JavaScript key) as KAKAO_CLIENT_ID
# Kakao Login > Redirect URI: http://localhost:3000/auth/kakao/callback
# If Client Secret is enabled in Kakao security settings, set KAKAO_CLIENT_SECRET below.
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=

# Kakao Maps (JavaScript key) — 지도 임베드용. REST API 키와 별도.
# Console: 앱 > 플랫폼(웹 도메인 등록) > JavaScript 키
# Local: http://localhost:3000 등록 필요
KAKAO_MAP_JAVASCRIPT_KEY=your_kakao_javascript_key_here

# Admin — comma-separated emails OR identifiers (Google email local-part, name, id)
# dodamm111@gmail.com 계정은 ADMIN_IDENTIFIERS=dodamm111 로 자동 관리자 부여
ADMIN_IDENTIFIERS=dodamm111
ADMIN_EMAILS=
